#!/usr/bin/env bash

set -euo pipefail

# 로컬 pre-push Hook은 실제 품질·저장소 보호 문제만 차단한다.
# 하네스 메타데이터와 로그 형식 누락은 경고만 출력하며 Push를 막지 않는다.

issue=${HARNESS_ISSUE:-}
attempt=${HARNESS_ATTEMPT:-}
status=${HARNESS_STATUS:-}
repo_root=""
branch=""

block() {
  printf '%s\n' "$1" >&2
  exit 1
}

warn() {
  printf 'PUSH WARNING: %s\n' "$1" >&2
}

if ! repo_root=$(git rev-parse --show-toplevel 2>/dev/null); then
  block 'git repository root not found'
fi

if ! branch=$(git -C "$repo_root" branch --show-current 2>/dev/null); then
  block 'current branch not found'
fi

if [ -z "$branch" ]; then
  block 'detached HEAD is not allowed'
fi

case "$branch" in
  main|develop)
    block 'direct push to protected branch is not allowed'
    ;;
esac

required_files=(
  "AGENTS.md"
  ".codex/skills/coffee-order-issue-loop/SKILL.md"
  ".codex/agents/planner.md"
  ".codex/agents/implementer.md"
  ".codex/agents/reviewer.md"
  ".codex/hooks/require-log.sh"
  ".codex/hooks/report-github-status.sh"
  ".githooks/pre-push"
  "logs/README.md"
  "logs/attempt-log-template.md"
  "logs/verification-log.md"
)

for file in "${required_files[@]}"; do
  if [ ! -f "$repo_root/$file" ]; then
    block "required harness file not found: $file"
  fi
done

bash -n "$repo_root/.codex/hooks/require-log.sh"
bash -n "$repo_root/.codex/hooks/report-github-status.sh"
bash -n "$repo_root/.githooks/pre-push"

if ! printf '%s' "$issue" | grep -Eq '^[1-9][0-9]*$'; then
  warn 'HARNESS_ISSUE is missing or invalid; Issue linkage will be checked in the PR body'
fi

case "$attempt" in
  "") warn 'HARNESS_ATTEMPT is not set' ;;
  1|2) ;;
  *) warn 'HARNESS_ATTEMPT should be 1 or 2' ;;
esac

case "$status" in
  "") warn 'HARNESS_STATUS is not set' ;;
  PASS|FAIL|BLOCKED) ;;
  *) warn 'HARNESS_STATUS should be PASS, FAIL, or BLOCKED' ;;
esac

if printf '%s' "$issue" | grep -Eq '^[1-9][0-9]*$' \
  && printf '%s' "$attempt" | grep -Eq '^[12]$' \
  && printf '%s' "$status" | grep -Eq '^(PASS|FAIL|BLOCKED)$'; then
  set +e
  bash "$repo_root/.codex/hooks/require-log.sh" \
    --issue "$issue" \
    --attempt "$attempt" \
    --status "$status"
  enforcement_rc=$?
  set -e

  if [ "$enforcement_rc" -ne 0 ]; then
    warn 'harness log evidence is incomplete; Push continues, but the record should be corrected before review'
  fi
else
  warn 'harness log evidence check skipped because metadata is incomplete'
fi

printf '%s\n' 'PUSH CHECK PASSED'
printf 'Branch: %s\n' "$branch"
printf '%s\n' 'Blocking checks: protected branch, required files, Bash syntax'
exit 0
