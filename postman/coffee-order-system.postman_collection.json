              ]
            },
            "description": "사용자 포인트를 정상 충전한다."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('response has charge data', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data).to.include.keys(['userId', 'chargedAmount', 'balance']);",
                  "});"
                ]
              }
            }
